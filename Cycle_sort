import java.util.*;
class cycle {
    public static void main(String[] args) {
      int arr[]={5,3,2,4,1};
      int i=1;
      while(i<arr.length){
          int c=i;
          if(arr[i]!=c){
              int temp=arr[i];
              arr[i]=arr[c];
              arr[c]=temp;
            
          }
          else{
              i++;
          }
      }
      System.out.print(Arrays.toString(arr));
    }
}
