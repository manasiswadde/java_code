//You are given a string "number" representing a positive integer and a character digit.
Return the resulting string after removing exactly one occurrence of digit from number such that the value of the resulting string in decimal form is maximized.
The test cases are generated such that digit occurs at least once in the number.
I/P: number = "1321"
digit = 1
O/P: 321


class Main {
    public static void main(String[] args) {
       String num="1231";
       char d='1';
       int max=Integer.MIN_VALUE;
       
       for(int i=0;i<num.length();i++){
           String temp=num.substring(0,i)+num.substring(i+1);
           int val=Integer.parseInt(temp);
           if(max<val){
               max=val;
           }
       }
       System.out.println(max);
    }
}

